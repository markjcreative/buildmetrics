# BuildMetrics — Hostinger Apache config

Options -Indexes

# Directory index
DirectoryIndex index.html index.php

# URL routing
RewriteEngine On
RewriteBase /

# Redirect old sign-up URL
RewriteRule ^sign-up/?$ /signup [R=301,L]

# Clean URLs — serve /dashboard as /dashboard.html etc.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

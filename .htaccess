# BuildMetrics — Hostinger Apache config

Options -Indexes

# ── Browser Cache Control ──────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — always revalidate so users get fresh pages after every deploy
  ExpiresByType text/html                 "access plus 0 seconds"

  # JS & CSS — 24-hour cache, auto-expires after 1 day
  ExpiresByType application/javascript    "access plus 1 day"
  ExpiresByType text/javascript           "access plus 1 day"
  ExpiresByType text/css                  "access plus 1 day"

  # Fonts — 7 days (rarely change)
  ExpiresByType font/woff2                "access plus 7 days"
  ExpiresByType font/woff                 "access plus 7 days"
  ExpiresByType application/font-woff2    "access plus 7 days"

  # Images — 7 days
  ExpiresByType image/png                 "access plus 7 days"
  ExpiresByType image/jpeg                "access plus 7 days"
  ExpiresByType image/svg+xml             "access plus 7 days"
  ExpiresByType image/webp                "access plus 7 days"
  ExpiresByType image/x-icon              "access plus 7 days"

  # API / JSON — never cache
  ExpiresByType application/json          "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  # HTML — must revalidate every request
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # JS & CSS — 24-hour public cache
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # Fonts & images — 7-day cache
  <FilesMatch "\.(woff2?|ttf|eot|png|jpe?g|svg|webp|ico)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  # PHP / API — never cache
  <FilesMatch "\.php$">
    Header set Cache-Control "no-store, no-cache, must-revalidate"
    Header set Pragma "no-cache"
  </FilesMatch>
</IfModule>

# Directory index
DirectoryIndex index.html index.php

# URL routing
RewriteEngine On
RewriteBase /

# Redirect old sign-up URL
RewriteRule ^sign-up/?$ /signup [R=301,L]

# Clean URLs — serve /dashboard as /dashboard.html etc.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

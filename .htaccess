# BuildMetrics — Hostinger Apache config

Options -Indexes

# ── Browser Cache Control ──────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — always revalidate so users get fresh pages after every deploy
  ExpiresByType text/html                 "access plus 0 seconds"

  # JS & CSS — 24-hour cache, auto-expires after 1 day
  ExpiresByType application/javascript    "access plus 1 day"
  ExpiresByType text/javascript           "access plus 1 day"
  ExpiresByType text/css                  "access plus 1 day"

  # Fonts — 7 days (rarely change)
  ExpiresByType font/woff2                "access plus 7 days"
  ExpiresByType font/woff                 "access plus 7 days"
  ExpiresByType application/font-woff2    "access plus 7 days"

  # Images — 7 days
  ExpiresByType image/png                 "access plus 7 days"
  ExpiresByType image/jpeg                "access plus 7 days"
  ExpiresByType image/svg+xml             "access plus 7 days"
  ExpiresByType image/webp                "access plus 7 days"
  ExpiresByType image/x-icon              "access plus 7 days"

  # API / JSON — never cache
  ExpiresByType application/json          "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  # HTML — must revalidate every request
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # JS & CSS — 24-hour public cache
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # Fonts & images — 7-day cache
  <FilesMatch "\.(woff2?|ttf|eot|png|jpe?g|svg|webp|ico)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  # PHP / API — never cache
  <FilesMatch "\.php$">
    Header set Cache-Control "no-store, no-cache, must-revalidate"
    Header set Pragma "no-cache"
  </FilesMatch>

  # ── Security headers ─────────────────────────────────────────────────────
  # Force HTTPS for a year (apex/app domain). Add includeSubDomains only once
  # every subdomain is confirmed HTTPS-only.
  Header always set Strict-Transport-Security "max-age=31536000"
  # Clickjacking protection
  Header always set X-Frame-Options "SAMEORIGIN"
  # Block MIME-type sniffing
  Header always set X-Content-Type-Options "nosniff"
  # Limit referrer leakage
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # Disable powerful features the app doesn't use
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
  # Content Security Policy — allowlists exactly the external origins in use.
  # 'unsafe-inline' is retained (app uses inline handlers/styles); stored content
  # is escaped server/client-side so inline injection is neutralised.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://unpkg.com https://accounts.google.com https://apis.google.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://accounts.google.com; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: blob: https:; connect-src 'self' https://accounts.google.com https://oauth2.googleapis.com https://www.googleapis.com https://api.postcodes.io; frame-src 'self' https://accounts.google.com https://content.googleapis.com; frame-ancestors 'self'; object-src 'none'; base-uri 'self'; form-action 'self'"
</IfModule>

# Directory index
DirectoryIndex index.html index.php

# URL routing
RewriteEngine On
RewriteBase /

# Force HTTPS (skip if already https, e.g. behind Hostinger SSL proxy)
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !=https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Redirect old sign-up URL
RewriteRule ^sign-up/?$ /signup [R=301,L]

# Clean URLs — serve /dashboard as /dashboard.html etc.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
